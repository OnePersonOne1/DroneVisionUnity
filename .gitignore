Python/__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.Python
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# 정보서비스 캐시·데이터
Python/info_service/data/*.geojson
Python/info_service/data/*.json
Python/info_service/__pycache__/

