<?xml version="1.0" encoding="UTF-8"?>
<!-- PX4 gz SITL world — 원점(spherical_coordinates)을 인천 앵커로 설정.
     gz Harmonic 에서는 PX4_HOME_LAT/LON 이 world 의 spherical_coordinates 를 override 하지
     못하므로(경험적 확인), 원점 자체를 여기서 인천으로 박는다. CubeGPSDisplay.anchor 와 일치
     → SITL 드론이 인천 맵 좌표계 위에 정확히 배치된다.
     PX4_GZ_WORLD=incheon 으로 선택. default.sdf 와 spherical_coordinates 외 동일. -->
<sdf version="1.9">
  <world name="incheon">
    <physics type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
    </physics>
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>
    <scene>
      <grid>false</grid>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>true</shadows>
    </scene>
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>1 1</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode/>
            </friction>
            <bounce/>
            <contact/>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>500 500</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
        <pose>0 0 0 0 -0 0</pose>
        <inertial>
          <pose>0 0 0 0 -0 0</pose>
          <mass>1</mass>
          <inertia>
            <ixx>1</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>1</iyy>
            <iyz>0</iyz>
            <izz>1</izz>
          </inertia>
        </inertial>
        <enable_wind>false</enable_wind>
      </link>
      <pose>0 0 0 0 -0 0</pose>
      <self_collide>false</self_collide>
    </model>
    <light name="sunUTC" type="directional">
      <pose>0 0 500 0 -0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1</intensity>
      <direction>0.001 0.625 -0.78</direction>
      <diffuse>0.904 0.904 0.904 1</diffuse>
      <specular>0.271 0.271 0.271 1</specular>
      <attenuation>
        <range>2000</range>
        <linear>0</linear>
        <constant>1</constant>
        <quadratic>0</quadratic>
      </attenuation>
      <spot>
        <inner_angle>0</inner_angle>
        <outer_angle>0</outer_angle>
        <falloff>0</falloff>
      </spot>
    </light>
    <!-- 원점 = 씬 CubeGPSDisplay 의 실제 anchorLatitude/Longitude (단일 진실 공급원).
         CLAUDE.md 의 37.384312/126.655307 는 stale 문서값 — 실제 씬은 아래로 재보정됨.
         이 값이 anchor 와 일치해야 SITL 드론이 anchorObject 위치에 정확히 스폰된다. -->
    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>37.384049721493724</latitude_deg>
      <longitude_deg>126.65615666326806</longitude_deg>
      <elevation>5</elevation>
    </spherical_coordinates>
  </world>
</sdf>
